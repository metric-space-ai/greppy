# The benchmark corpus is generated and git-initialised per-repo by
# gen_corpus.sh. It is intentionally NOT committed to the outer repo:
#  * each corpus repo has its own .git (committing would create broken
#    embedded gitlinks), and
#  * it is fully reproducible -- run `bash gen_corpus.sh` to materialise it.

# Per-run benchmark output (token/time rows) -- regenerated by run_bench.py.
results.json

# Raw pi JSONL traces can contain large source snippets and full agent tool
# trajectories. Keep them local unless a specific forensic sample is curated.
raw_runs/

# Local quantized EmbeddingGemma prototype index (optional diagnostic
# retrieval experiments). Not produced by the default harness.
embeddinggemma_index/

# Python bytecode
__pycache__/
*.pyc
acceptance_runs/
