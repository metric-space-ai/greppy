crates/cli/tests/assets/ci-test/** -text

# Redistribution lock records are hashed byte-for-byte on every release
# platform. Keep LF checkout bytes stable when Git runs on Windows.
licenses/*.html text eol=lf
licenses/*.json text eol=lf
licenses/*.txt text eol=lf
training/qwen35/*.json text eol=lf
training/qwen35/*.sha256 text eol=lf

# Benchmark harness + drivers are tooling, not the shipped product (a single
# native Rust binary). Exclude from GitHub's language stats so the repo language
# breakdown reflects the product, not the eval scripts.
bench/** linguist-vendored
*.sh linguist-vendored
# Model-asset pins must be byte-identical on every OS (the redistribution
# lock hashes the sidecar/manifest files themselves) - no EOL normalization.
crates/cli/assets/** -text
